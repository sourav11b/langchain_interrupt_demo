# ─────────────────────────────────────────────────────────────────────────────
#  VaultIQ — environment variables (copy to .env and fill in)
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pwd>@<cluster>.mongodb.net/?appName=<name>

# Atlas Admin API
ATLAS_API_CLIENT_ID=
ATLAS_API_CLIENT_SECRET=
ATLAS_API_PROJECT_ID=
ATLAS_API_CLUSTER_NAME=

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ── OpenAI fallback (optional) ───────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_API_TYPE=azure_ad

# ── Voyage AI ────────────────────────────────────────────────────────────────
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-finance-2

# ── LangSmith ────────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=vaultiq-fsi

# ── MCP servers ──────────────────────────────────────────────────────────────
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=8100

MONGODB_MCP_TRANSPORT=embedded
MONGODB_MCP_HOST=localhost
MONGODB_MCP_PORT=3001
MONGODB_MCP_READ_ONLY=true

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=demo
LOG_LEVEL=INFO
